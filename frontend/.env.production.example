# ===========================================
# Parse Frontend - Production Environment
# ===========================================
# Copy this file to .env.local and fill in the values
# These are set in Vercel dashboard for production

# ===========================================
# REQUIRED VARIABLES
# ===========================================

# Backend API URL (your Railway deployment)
NEXT_PUBLIC_API_URL="https://your-backend.railway.app/api"

# WebSocket URL for real-time features
NEXT_PUBLIC_SOCKET_URL="https://your-backend.railway.app"

# ===========================================
# ERROR MONITORING - SENTRY
# ===========================================

# Sentry DSN for error tracking
# Get from: https://sentry.io/ -> Project Settings -> Client Keys
NEXT_PUBLIC_SENTRY_DSN="https://xxx@xxx.ingest.sentry.io/xxx"

# Sentry Auth Token (for source maps upload during build)
# Get from: https://sentry.io/settings/account/api/auth-tokens/
SENTRY_AUTH_TOKEN="sntrys_..."

# Sentry Organization and Project slugs
SENTRY_ORG="your-org"
SENTRY_PROJECT="parse-frontend"

# ===========================================
# OPTIONAL VARIABLES
# ===========================================

# Enable debug mode
NEXT_PUBLIC_DEBUG=""

# Analytics (if using external analytics)
# NEXT_PUBLIC_GA_ID="G-..."
# NEXT_PUBLIC_MIXPANEL_TOKEN="..."
