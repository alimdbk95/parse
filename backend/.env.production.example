# ===========================================
# Parse Backend - Production Environment
# ===========================================
# Copy this file to .env and fill in the values
# NEVER commit .env to version control

# ===========================================
# REQUIRED VARIABLES
# ===========================================

# Database (PostgreSQL)
# Railway auto-provides this when you link PostgreSQL
DATABASE_URL="postgresql://user:password@host:5432/database?sslmode=require"

# JWT Secret - MUST be at least 32 characters
# Generate with: openssl rand -base64 32
JWT_SECRET="your-secure-random-string-at-least-32-chars"

# Port for the server
PORT=3001

# Frontend URL for CORS
FRONTEND_URL="https://your-app.vercel.app"

# ===========================================
# AI SERVICES (Required for AI features)
# ===========================================

# Anthropic Claude API Key
# Get from: https://console.anthropic.com/
ANTHROPIC_API_KEY="sk-ant-api03-..."

# ===========================================
# EMAIL SERVICE (Required for auth emails)
# ===========================================

# Resend API Key for transactional emails
# Get from: https://resend.com/api-keys
RESEND_API_KEY="re_..."

# Email sender address (must be verified in Resend)
EMAIL_FROM="Parse <noreply@yourdomain.com>"

# ===========================================
# FILE STORAGE - AWS S3
# ===========================================

# AWS Credentials
# Create IAM user with S3 permissions
AWS_ACCESS_KEY_ID="AKIA..."
AWS_SECRET_ACCESS_KEY="..."
AWS_REGION="us-east-1"

# S3 Bucket name (must exist)
AWS_S3_BUCKET="parse-uploads-production"

# ===========================================
# ERROR MONITORING - SENTRY
# ===========================================

# Sentry DSN for error tracking
# Get from: https://sentry.io/ -> Project Settings -> Client Keys
SENTRY_DSN="https://xxx@xxx.ingest.sentry.io/xxx"

# ===========================================
# OPTIONAL VARIABLES
# ===========================================

# Node environment
NODE_ENV="production"

# Enable debug logging (set to "true" for troubleshooting)
DEBUG=""

# Maximum file upload size in bytes (default: 500MB)
MAX_FILE_SIZE=524288000
