generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(uuid())
  email         String    @unique
  password      String
  name          String
  avatar        String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // Branding preferences
  brandColors       String?   // JSON string of color palette
  brandLogo         String?
  brandFont         String?
  brandFontSize     String?   // small, medium, large
  brandPrimaryColor String?   // Hex color
  brandAccentColor  String?   // Hex color
  brandTextColor    String?   // Hex color for text
  brandBackgroundColor String? // Hex color for background
  brandChartBg      String?   // dark, light, transparent
  theme             String    @default("dark")

  // Relations
  workspaces    WorkspaceMember[]
  ownedWorkspaces Workspace[] @relation("WorkspaceOwner")
  documents     Document[]
  analyses      Analysis[]
  charts        Chart[]
  messages      Message[]
  comments      Comment[]
  compareSessions CompareSession[]
  repositories  Repository[]
  notifications Notification[]
  templates     Template[]
  chartAnnotations ChartAnnotation[]
  documentHighlights DocumentHighlight[]
  analysisVersions AnalysisVersion[]
  knowledgeGraphs KnowledgeGraph[]
  dataTables    DataTable[]
  timelines     Timeline[]
  mediaFiles    MediaFile[]
  experiments   Experiment[]
}

model Workspace {
  id          String    @id @default(uuid())
  name        String
  description String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  // Owner
  ownerId     String
  owner       User      @relation("WorkspaceOwner", fields: [ownerId], references: [id])

  // Relations
  members     WorkspaceMember[]
  documents   Document[]
  analyses    Analysis[]
  charts      Chart[]
  invitations Invitation[]
  templates   Template[]
}

model WorkspaceMember {
  id          String    @id @default(uuid())
  role        String    @default("viewer") // admin, editor, viewer
  joinedAt    DateTime  @default(now())

  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([userId, workspaceId])
}

model Document {
  id          String    @id @default(uuid())
  name        String
  type        String    // pdf, csv, excel, image
  size        Int
  path        String
  mimeType    String
  content     String?   // Extracted text content
  metadata    String?   // JSON string of extracted metadata
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  // Relations
  uploadedById String
  uploadedBy   User      @relation(fields: [uploadedById], references: [id])

  workspaceId  String?
  workspace    Workspace? @relation(fields: [workspaceId], references: [id])

  analyses     AnalysisDocument[]
  semanticInsights SemanticInsight[]
  highlights   DocumentHighlight[]
}

model Analysis {
  id          String    @id @default(uuid())
  title       String
  description String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  // Relations
  createdById String
  createdBy   User      @relation(fields: [createdById], references: [id])

  workspaceId String?
  workspace   Workspace? @relation(fields: [workspaceId], references: [id])

  documents   AnalysisDocument[]
  messages    Message[]
  charts      Chart[]
  semanticInsights SemanticInsight[]
  versions    AnalysisVersion[]
  parameters  AnalysisParameter[]
}

model AnalysisDocument {
  id          String    @id @default(uuid())
  addedAt     DateTime  @default(now())

  analysisId  String
  analysis    Analysis  @relation(fields: [analysisId], references: [id], onDelete: Cascade)

  documentId  String
  document    Document  @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@unique([analysisId, documentId])
}

// Analysis Parameters - User-defined key-value parameters for analyses
model AnalysisParameter {
  id          String    @id @default(uuid())
  key         String    // Parameter name
  value       String    // Parameter value
  comment     String?   // Google Sheets-style note/comment
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  // Relations
  analysisId  String
  analysis    Analysis  @relation(fields: [analysisId], references: [id], onDelete: Cascade)

  @@unique([analysisId, key])
  @@index([analysisId])
}

model Message {
  id          String    @id @default(uuid())
  role        String    // user, assistant
  content     String
  metadata    String?   // JSON string for charts, data references, etc.
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @default(now()) @updatedAt
  isEdited    Boolean   @default(false)

  // Relations
  analysisId  String
  analysis    Analysis  @relation(fields: [analysisId], references: [id], onDelete: Cascade)

  userId      String?
  user        User?     @relation(fields: [userId], references: [id])

  comments    Comment[]
}

model Chart {
  id          String    @id @default(uuid())
  title       String
  type        String    // bar, line, pie, area, scatter
  data        String    // JSON string of chart data
  config      String    // JSON string of chart configuration
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  // Customization
  colors      String?   // JSON array of colors
  background  String    @default("dark") // light, dark, transparent
  fontFamily  String?
  showLegend  Boolean   @default(true)
  showGrid    Boolean   @default(true)

  // Relations
  createdById String
  createdBy   User      @relation(fields: [createdById], references: [id])

  workspaceId String?
  workspace   Workspace? @relation(fields: [workspaceId], references: [id])

  analysisId  String?
  analysis    Analysis? @relation(fields: [analysisId], references: [id])

  annotations ChartAnnotation[]
}

model Invitation {
  id          String    @id @default(uuid())
  email       String
  role        String    @default("viewer")
  token       String    @unique
  expiresAt   DateTime
  createdAt   DateTime  @default(now())

  // Track invitation sender
  invitedById String?

  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
  @@index([email])
}

model CompareSession {
  id          String    @id @default(uuid())
  title       String
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  // Relations
  createdById String
  createdBy   User      @relation(fields: [createdById], references: [id])

  workspaceId String?

  items       CompareItem[]
  comments    Comment[]
}

model CompareItem {
  id          String    @id @default(uuid())
  type        String    // document, chart, link, pdf
  title       String
  content     String?   // For links: URL, for text content
  data        String?   // JSON string for chart data or metadata
  position    Int       @default(0) // Order in comparison
  createdAt   DateTime  @default(now())

  // Relations
  sessionId   String
  session     CompareSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  documentId  String?   // If linked to a document
  chartId     String?   // If linked to a chart

  comments    Comment[]
}

model Comment {
  id          String    @id @default(uuid())
  content     String
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  // Relations
  authorId    String
  author      User      @relation(fields: [authorId], references: [id])

  sessionId   String?
  session     CompareSession? @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  itemId      String?
  item        CompareItem? @relation(fields: [itemId], references: [id], onDelete: Cascade)

  // For message comments (editable outcomes)
  messageId   String?
  message     Message? @relation(fields: [messageId], references: [id], onDelete: Cascade)
}

model Repository {
  id          String    @id @default(uuid())
  name        String
  description String?
  color       String?   // Hex color for visual identification
  icon        String?   // Icon name for the repository
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  // Relations
  ownerId     String
  owner       User      @relation(fields: [ownerId], references: [id])

  // Items in repository
  analyses    RepositoryAnalysis[]
  documents   RepositoryDocument[]
  comparisons RepositoryComparison[]
}

model RepositoryAnalysis {
  id          String    @id @default(uuid())
  addedAt     DateTime  @default(now())

  repositoryId String
  repository   Repository @relation(fields: [repositoryId], references: [id], onDelete: Cascade)

  analysisId  String

  @@unique([repositoryId, analysisId])
}

model RepositoryDocument {
  id          String    @id @default(uuid())
  addedAt     DateTime  @default(now())

  repositoryId String
  repository   Repository @relation(fields: [repositoryId], references: [id], onDelete: Cascade)

  documentId  String

  @@unique([repositoryId, documentId])
}

model RepositoryComparison {
  id          String    @id @default(uuid())
  addedAt     DateTime  @default(now())

  repositoryId String
  repository   Repository @relation(fields: [repositoryId], references: [id], onDelete: Cascade)

  comparisonId String

  @@unique([repositoryId, comparisonId])
}

model Notification {
  id        String   @id @default(uuid())
  type      String   // 'comment', 'mention', 'workspace_invite', 'analysis_shared'
  title     String
  message   String
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  // Who receives the notification
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Optional references for navigation
  analysisId  String?
  messageId   String?
  workspaceId String?
  commentId   String?

  // Who triggered the notification (optional)
  actorId   String?
  actorName String?
}

// Template Builder - reusable report templates
model Template {
  id          String    @id @default(uuid())
  name        String
  description String?
  thumbnail   String?   // Preview image URL
  isPublic    Boolean   @default(false)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  // Relations
  createdById String
  createdBy   User      @relation(fields: [createdById], references: [id])

  workspaceId String?
  workspace   Workspace? @relation(fields: [workspaceId], references: [id])

  sections    TemplateSection[]
}

model TemplateSection {
  id          String    @id @default(uuid())
  type        String    // 'text', 'chart', 'heading', 'divider', 'image', 'table'
  content     String?   // JSON string with section-specific content
  position    Int       @default(0)
  width       String    @default("full") // 'full', 'half', 'third'
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  // Relations
  templateId  String
  template    Template  @relation(fields: [templateId], references: [id], onDelete: Cascade)

  // Optional link to existing chart
  chartId     String?
}

// Chart Annotations - notes on specific data points
model ChartAnnotation {
  id          String    @id @default(uuid())
  content     String    // The annotation text
  dataIndex   Int       // Index of the data point being annotated
  dataKey     String?   // Which data series (for multi-series charts)
  x           Float?    // X position for free-form annotations
  y           Float?    // Y position for free-form annotations
  color       String?   // Annotation color
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  // Relations
  chartId     String
  chart       Chart     @relation(fields: [chartId], references: [id], onDelete: Cascade)

  createdById String
  createdBy   User      @relation(fields: [createdById], references: [id])
}

// Semantic Analysis - AI-extracted insights from documents
model SemanticInsight {
  id          String    @id @default(uuid())
  type        String    // 'theme', 'entity', 'sentiment', 'keyphrase', 'summary'
  label       String    // The identified theme/entity/phrase
  value       String?   // Additional value (e.g., sentiment score, frequency)
  confidence  Float?    // AI confidence score 0-1
  context     String?   // Surrounding text or source reference
  metadata    String?   // JSON string for additional data
  createdAt   DateTime  @default(now())

  // Relations
  documentId  String
  document    Document  @relation(fields: [documentId], references: [id], onDelete: Cascade)

  analysisId  String?
  analysis    Analysis? @relation(fields: [analysisId], references: [id], onDelete: Cascade)
}

// Smart Highlights - AI-detected important content in documents
model DocumentHighlight {
  id          String    @id @default(uuid())
  type        String    // 'fact', 'statistic', 'claim', 'definition', 'quote', 'conclusion'
  text        String    // The highlighted text
  startOffset Int       // Character offset where highlight starts
  endOffset   Int       // Character offset where highlight ends
  importance  String    // 'critical', 'high', 'medium', 'low'
  category    String?   // Optional category for grouping (e.g., 'financial', 'technical')
  explanation String?   // AI explanation of why this is important
  confidence  Float?    // AI confidence score 0-1
  isUserAdded Boolean   @default(false) // True if user manually added
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  // Relations
  documentId  String
  document    Document  @relation(fields: [documentId], references: [id], onDelete: Cascade)

  createdById String?
  createdBy   User?     @relation(fields: [createdById], references: [id])

  @@index([documentId])
}

// Analysis Version History - track changes over time
model AnalysisVersion {
  id          String    @id @default(uuid())
  version     Int       // Incremental version number
  title       String    // Analysis title at this version
  description String?   // Analysis description at this version
  snapshot    String    // JSON snapshot of analysis state (messages, charts, documents)
  changeType  String    // 'message_added', 'message_edited', 'chart_added', 'document_added', 'title_changed', etc.
  changeSummary String? // Human-readable summary of what changed
  createdAt   DateTime  @default(now())

  // Relations
  analysisId  String
  analysis    Analysis  @relation(fields: [analysisId], references: [id], onDelete: Cascade)

  createdById String
  createdBy   User      @relation(fields: [createdById], references: [id])

  @@index([analysisId])
  @@index([createdAt])
}

// Knowledge Graph - Entity relationships visualization
model KnowledgeGraph {
  id          String    @id @default(uuid())
  name        String
  description String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  // Relations
  createdById String
  createdBy   User      @relation(fields: [createdById], references: [id])

  workspaceId String?
  analysisId  String?

  nodes       GraphNode[]
  edges       GraphEdge[]

  @@index([workspaceId])
  @@index([analysisId])
}

model GraphNode {
  id          String    @id @default(uuid())
  label       String    // Display name
  type        String    // 'person', 'organization', 'location', 'concept', 'event', 'document'
  properties  String?   // JSON string of additional properties
  x           Float?    // X position for layout
  y           Float?    // Y position for layout
  color       String?   // Node color
  size        Float     @default(1) // Node size multiplier
  sourceDocId String?   // Document this entity was extracted from
  createdAt   DateTime  @default(now())

  // Relations
  graphId     String
  graph       KnowledgeGraph @relation(fields: [graphId], references: [id], onDelete: Cascade)

  outgoingEdges GraphEdge[] @relation("SourceNode")
  incomingEdges GraphEdge[] @relation("TargetNode")

  @@index([graphId])
  @@index([type])
}

model GraphEdge {
  id          String    @id @default(uuid())
  label       String    // Relationship type (e.g., 'works_at', 'located_in', 'mentions')
  weight      Float     @default(1) // Edge strength/importance
  properties  String?   // JSON string of additional properties
  color       String?   // Edge color
  createdAt   DateTime  @default(now())

  // Relations
  graphId     String
  graph       KnowledgeGraph @relation(fields: [graphId], references: [id], onDelete: Cascade)

  sourceId    String
  source      GraphNode @relation("SourceNode", fields: [sourceId], references: [id], onDelete: Cascade)

  targetId    String
  target      GraphNode @relation("TargetNode", fields: [targetId], references: [id], onDelete: Cascade)

  @@index([graphId])
}

// Interactive Data Tables
model DataTable {
  id          String    @id @default(uuid())
  name        String
  description String?
  columns     String    // JSON array of column definitions [{name, type, formula?, width?}]
  data        String    // JSON array of row data
  config      String?   // JSON config (sorting, filtering, styling)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  // Relations
  createdById String
  createdBy   User      @relation(fields: [createdById], references: [id])

  workspaceId String?
  analysisId  String?
  documentId  String?   // If extracted from a document

  @@index([workspaceId])
  @@index([analysisId])
}

// Timeline Events
model Timeline {
  id          String    @id @default(uuid())
  name        String
  description String?
  startDate   DateTime?
  endDate     DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  // Relations
  createdById String
  createdBy   User      @relation(fields: [createdById], references: [id])

  workspaceId String?
  analysisId  String?

  events      TimelineEvent[]

  @@index([workspaceId])
  @@index([analysisId])
}

model TimelineEvent {
  id          String    @id @default(uuid())
  title       String
  description String?
  date        DateTime
  endDate     DateTime? // For events with duration
  type        String    @default("event") // 'event', 'milestone', 'period', 'deadline'
  category    String?   // For grouping/filtering
  color       String?   // Event color
  icon        String?   // Icon name
  importance  String    @default("medium") // 'low', 'medium', 'high', 'critical'
  sourceDocId String?   // Document this event was extracted from
  metadata    String?   // JSON string for additional data
  createdAt   DateTime  @default(now())

  // Relations
  timelineId  String
  timeline    Timeline  @relation(fields: [timelineId], references: [id], onDelete: Cascade)

  @@index([timelineId])
  @@index([date])
}

// Media Files - Audio/Video with transcription
model MediaFile {
  id          String    @id @default(uuid())
  name        String
  type        String    // 'audio', 'video'
  mimeType    String
  size        Int
  path        String
  duration    Float?    // Duration in seconds
  thumbnail   String?   // Thumbnail path for video
  waveform    String?   // JSON array of audio waveform data
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  // Transcription
  transcriptionStatus String @default("pending") // 'pending', 'processing', 'completed', 'failed'
  transcription       String? // Full text transcription
  transcriptionMeta   String? // JSON with word-level timestamps, speakers, etc.

  // Relations
  uploadedById String
  uploadedBy   User      @relation(fields: [uploadedById], references: [id])

  workspaceId String?
  analysisId  String?

  segments    MediaSegment[]

  @@index([workspaceId])
  @@index([analysisId])
}

model MediaSegment {
  id          String    @id @default(uuid())
  startTime   Float     // Start time in seconds
  endTime     Float     // End time in seconds
  text        String    // Transcribed text for this segment
  speaker     String?   // Speaker identification
  confidence  Float?    // Transcription confidence
  isEdited    Boolean   @default(false) // User edited the transcription
  notes       String?   // User notes for this segment
  tags        String?   // JSON array of tags
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  // Relations
  mediaId     String
  media       MediaFile @relation(fields: [mediaId], references: [id], onDelete: Cascade)

  @@index([mediaId])
  @@index([startTime])
}

// Design of Experiments (DoE) - Scientific experiment management
model Experiment {
  id              String    @id @default(uuid())
  name            String
  description     String?
  hypothesis      String?   // H0/H1 statement
  type            String    // 'ab_test', 'full_factorial', 'parameter_matrix', 'custom'
  status          String    @default("draft") // 'draft', 'running', 'paused', 'completed'
  confidenceLevel Float     @default(0.95)
  minimumSampleSize Int?
  powerAnalysis   String?   // JSON
  startedAt       DateTime?
  completedAt     DateTime?
  resultSummary   String?   // JSON: p-values, effect sizes, winner
  conclusion      String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  // Relations
  createdById     String
  createdBy       User      @relation(fields: [createdById], references: [id])
  workspaceId     String?
  analysisId      String?

  factors         ExperimentFactor[]
  variations      ExperimentVariation[]
  runs            ExperimentRun[]
  results         ExperimentResult[]
  metrics         ExperimentMetric[]

  @@index([workspaceId])
  @@index([status])
  @@index([type])
}

model ExperimentFactor {
  id            String    @id @default(uuid())
  name          String
  type          String    @default("categorical") // 'categorical', 'numeric', 'boolean'
  unit          String?
  description   String?
  minValue      Float?
  maxValue      Float?
  levels        String?   // JSON: ["low", "high"]
  position      Int       @default(0)
  createdAt     DateTime  @default(now())

  // Relations
  experimentId  String
  experiment    Experiment @relation(fields: [experimentId], references: [id], onDelete: Cascade)
  levelValues   FactorLevel[]

  @@index([experimentId])
}

model FactorLevel {
  id            String    @id @default(uuid())
  value         String
  label         String?
  isControl     Boolean   @default(false)
  createdAt     DateTime  @default(now())

  // Relations
  factorId      String
  factor        ExperimentFactor @relation(fields: [factorId], references: [id], onDelete: Cascade)

  @@index([factorId])
}

model ExperimentVariation {
  id            String    @id @default(uuid())
  name          String
  description   String?
  isControl     Boolean   @default(false)
  factorValues  String    // JSON: factor-level assignments
  trafficWeight Float?
  position      Int       @default(0)
  createdAt     DateTime  @default(now())

  // Relations
  experimentId  String
  experiment    Experiment @relation(fields: [experimentId], references: [id], onDelete: Cascade)
  runs          ExperimentRun[]
  results       ExperimentResult[]

  @@index([experimentId])
}

model ExperimentRun {
  id            String    @id @default(uuid())
  runNumber     Int
  status        String    @default("pending") // 'pending', 'running', 'completed', 'failed'
  inputParams   String?   // JSON: actual input values used
  startedAt     DateTime?
  completedAt   DateTime?
  duration      Float?    // Duration in seconds
  notes         String?
  metadata      String?   // JSON: additional run-specific data
  createdAt     DateTime  @default(now())

  // Relations
  experimentId  String
  experiment    Experiment @relation(fields: [experimentId], references: [id], onDelete: Cascade)
  variationId   String
  variation     ExperimentVariation @relation(fields: [variationId], references: [id], onDelete: Cascade)
  results       ExperimentResult[]

  @@index([experimentId])
  @@index([variationId])
  @@index([status])
}

model ExperimentMetric {
  id             String    @id @default(uuid())
  name           String
  type           String    @default("numeric") // 'numeric', 'percentage', 'boolean', 'categorical'
  unit           String?
  isPrimary      Boolean   @default(false)
  higherIsBetter Boolean   @default(true)
  baselineValue  Float?
  targetValue    Float?
  position       Int       @default(0)
  createdAt      DateTime  @default(now())

  // Relations
  experimentId   String
  experiment     Experiment @relation(fields: [experimentId], references: [id], onDelete: Cascade)
  results        ExperimentResult[]

  @@index([experimentId])
}

model ExperimentResult {
  id            String    @id @default(uuid())
  value         Float
  rawValue      String?
  sampleSize    Int       @default(1)
  standardError Float?
  variance      Float?
  measuredAt    DateTime  @default(now())

  // Relations
  experimentId  String
  experiment    Experiment @relation(fields: [experimentId], references: [id], onDelete: Cascade)
  variationId   String
  variation     ExperimentVariation @relation(fields: [variationId], references: [id], onDelete: Cascade)
  metricId      String
  metric        ExperimentMetric @relation(fields: [metricId], references: [id], onDelete: Cascade)
  runId         String?
  run           ExperimentRun? @relation(fields: [runId], references: [id], onDelete: SetNull)

  @@index([experimentId])
  @@index([variationId])
  @@index([metricId])
}
